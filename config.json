{
  "storage": {
    "rootDirectory": "/var/lib/registry"
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "realm": "Registry",
    "readTimeout": "600s",
    "writeTimeout": "600s",
    "auth": {
      "failDelay": 1,
      "htpasswd": {
        "path": "/etc/zot/htpasswd"
      }
    },
    "accessControl": {
      "repositories": {
        "**": {
          "anonymousPolicy": ["read"],
          "defaultPolicy": ["read", "create", "update", "delete"]
        }
      }
    },
    "compat": [
      "docker2s2"
    ]
  },
  "log": {
    "level": "debug"
  },
  "extensions": {
    "search": {
      "enable": true
    },
    "ui": {
      "enable": true
    },
    "sync": {
      "enable": true,
      "registries": [
        {
          "urls": [
            "https://registry-1.docker.io"
          ],
          "content": [
            {
              "prefix": "**",
              "destination": "",
              "platforms": [
                { "os": "linux", "arch": "arm64" },
                { "os": "linux", "arch": "amd64" }
              ]
            }
          ],
          "onDemand": true,
          "tlsVerify": true
        },
        {
          "urls": ["https://quay.io"],
          "hostPrefix": "quay",
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m",
          "preserveDigest": true,
          "syncTimeout": "10m",
          "content": [{
            "prefix": "**",
            "tags": { "regex": ".*" },
            "platforms": [
              { "os": "linux", "arch": "arm64" },
              { "os": "linux", "arch": "amd64" }
            ]
          }]
        },
        {
          "urls": ["https://ghcr.io"],
          "hostPrefix": "ghcr",
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m",
          "preserveDigest": true,
          "syncTimeout": "10m",
          "content": [{
            "prefix": "**",
            "tags": { "regex": ".*" },
            "platforms": [
              { "os": "linux", "arch": "arm64" },
              { "os": "linux", "arch": "amd64" }
            ]
          }]
        },
        {
          "urls": ["https://gcr.io"],
          "hostPrefix": "gcr",
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m",
          "preserveDigest": true,
          "syncTimeout": "10m",
          "content": [{
            "prefix": "**",
            "tags": { "regex": ".*" },
            "platforms": [
              { "os": "linux", "arch": "arm64" },
              { "os": "linux", "arch": "amd64" }
            ]
          }]
        },
        {
          "urls": ["https://registry.k8s.io"],
          "hostPrefix": "k8s",
          "onDemand": true,
          "tlsVerify": true,
          "maxRetries": 3,
          "retryDelay": "5m",
          "preserveDigest": true,
          "syncTimeout": "10m",
          "content": [{
            "prefix": "**",
            "tags": { "regex": ".*" },
            "platforms": [
              { "os": "linux", "arch": "arm64" },
              { "os": "linux", "arch": "amd64" }
            ]
          }]
        }
      ]
    }
  }
}
